# GitHub personal access token (needs repo read access)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username
GITHUB_OWNER=your-github-username

# Name of the private repo you'll create
GITHUB_REPO=galaxy-vault

# Comma-separated API keys — generate one per user (you + Vinod)
# Generate with: openssl rand -hex 32
API_KEYS=key-for-priya,key-for-vinod

PORT=3000
